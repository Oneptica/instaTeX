{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latexgo.app/texshelf.schema.json",
  "title": "TeXShelf Entry",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "category", "subcategory", "latex", "tags"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "kind": {
        "type": "string",
        "enum": ["formula", "plot"]
      },
      "category": {
        "type": "string",
        "description": "Human-readable category. Must match the first-level folder under formulas/ or plots/.",
        "enum": [
          "Algebra",
          "Calculus",
          "Linear Algebra",
          "Probability",
          "Physics",
          "Chemistry",
          "Engineering",
          "Control Theory",
          "Signal Processing",
          "Image Processing"
        ]
      },
      "subcategory": {
        "type": "string",
        "description": "Human-readable subcategory. Must match the JSON filename under the category folder.",
        "minLength": 1
      },
      "latex": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string"
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "minItems": 1,
        "uniqueItems": true
      },
      "source": {
        "type": "string"
      }
    }
  }
}
